{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gutenberg-chess/chess-game",
	"version": "0.1.0",
	"title": "Chess Game",
	"category": "games",
	"icon": "games",
	"description": "Chess Game",
	"example": {},
	"attributes": {
		"moves": {
			"type": "array",
			"default": []
		},
		"whitePlayerId": {
			"type": "number",
			"default": 0
		},
		"blackPlayerId": {
			"type": "number",
			"default": 0
		}
	},
	"providesContext": {
		"gutenberg-chess/moves": "moves"
	},
	"supports": {
		"html": false
	},
	"textdomain": "gutenberg-chess",
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
