{
	"name": "gutenberg-chess",
	"version": "0.1.4",
	"description": "Real-time collaborative chess blocks for WordPress.",
	"author": "Julien Verneaut <jverneaut@gmail.com>",
	"license": "MIT",
	"files": [
		"build",
		"vendor",
		"GutenbergChess",
		"gutenberg-chess.php",
		"gutenberg-chess-class.php",
		"README.md"
	],
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build --blocks-manifest",
		"format": "prettier --write .",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "wp-scripts start --blocks-manifest"
	},
	"dependencies": {
		"@wordpress/block-editor": "latest",
		"@wordpress/blocks": "latest",
		"@wordpress/i18n": "latest",
		"chess.js": "^1.4.0",
		"prettier": "^3.8.1",
		"react-chessboard": "^5.10.0"
	},
	"devDependencies": {
		"@wordpress/scripts": "^31.8.0"
	}
}
